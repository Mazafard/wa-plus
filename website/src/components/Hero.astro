---
---
<section class="curtain-section z-[1] !shadow-none !border-t-0" id="hero">
    <div class="container hero flex flex-col items-center text-center pt-[100px] pb-[60px] relative">
        <div class="absolute -top-[100px] left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-[radial-gradient(circle,rgba(16,185,129,0.1)_0%,rgba(9,9,11,0)_70%)] -z-10 pointer-events-none"></div>
        <div class="bg-primary/10 text-emerald-400 py-2 px-[18px] rounded-[30px] text-[14px] font-semibold mt-24 mb-8 border border-emerald-400/20 shadow-[0_0_20px_rgba(16,185,129,0.1)]">WA+ v1.1.5 is Live!</div>
        <h1 class="text-[72px] leading-[1.05] tracking-[-2px] m-0 mb-6 bg-gradient-to-b from-white to-zinc-400 text-transparent bg-clip-text">Export WhatsApp<br>Groups Instantly</h1>
        <p class="text-[22px] text-text-muted max-w-[640px] m-0 mb-12 leading-[1.6]">Extract participants, phone numbers, and avatars directly from your active WhatsApp Web sessions. 100% local. Zero database lag. Maximum privacy.</p>
        
        <div class="flex gap-5 justify-center items-center">
            <a href="https://chromewebstore.google.com/detail/wa+/fkhdjggogknhlhaopaameedhchhoomhm" target="_blank" rel="noopener noreferrer" class="bg-primary text-white py-4 px-9 rounded-2xl text-[18px] font-semibold no-underline transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] shadow-[0_8px_24px_-6px_rgba(16,185,129,0.5)] font-inter relative overflow-hidden hover:-translate-y-[3px] hover:scale-[1.02] hover:shadow-[0_12px_30px_-8px_rgba(16,185,129,0.6)] hover:bg-primary-hover group">
                <span class="relative z-10">Add to Chrome 👀 It's Free</span>
                <div class="absolute top-0 -left-full w-1/2 h-full bg-gradient-to-r from-transparent via-white/20 to-transparent transition-all duration-500 group-hover:left-full"></div>
            </a>
            <a href="#" class="bg-surface text-text-main border border-border-subtle py-4 px-9 rounded-2xl text-[18px] font-semibold no-underline transition-all relative overflow-visible hover:bg-zinc-800/80 hover:border-white/20 hover:shadow-[0_12px_30px_rgba(0,0,0,0.4)] group" onclick="event.preventDefault()">
                Add to Firefox
                <span class="absolute -top-3 -right-[15px] bg-gradient-to-br from-amber-500 to-amber-700 text-white text-[11px] py-1 px-[10px] rounded-[12px] font-extrabold shadow-[0_4px_12px_rgba(245,158,11,0.4)] rotate-6 transition-transform duration-300 ease-[cubic-bezier(0.175,0.885,0.32,1.275)] group-hover:rotate-12 group-hover:scale-110">Coming Soon</span>
            </a>
        </div>

        <div class="hero-image mt-20 w-full max-w-[960px] rounded-3xl shadow-[0_30px_60px_-15px_rgba(0,0,0,0.6),0_0_0_1px_rgba(255,255,255,0.08)] overflow-hidden relative animate-[float_6s_ease-in-out_infinite] bg-black">
            <div class="absolute inset-0 shadow-[inset_0_0_0_1px_rgba(255,255,255,0.1)] rounded-3xl z-10 pointer-events-none"></div>
            <div class="absolute bottom-0 left-0 right-0 h-[250px] bg-gradient-to-t from-bg-color to-transparent z-5"></div>
            <img src="screenshot.png" alt="WA+ Extension UI on WhatsApp Web" class="w-full block -mt-[8%] -mb-[15%] filter contrast-105 brightness-105">
        </div>
    </div>
</section>

<style>
    @keyframes float {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-12px); }
        100% { transform: translateY(0px); }
    }
</style>
