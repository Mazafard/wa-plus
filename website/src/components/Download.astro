---

---

<section class="curtain-section z-[5]" id="download">
  <div class="container bottom-cta text-center flex flex-col items-center">
    <h2 class="text-[48px] mt-24 mb-6 tracking-[-1px]">
      Ready to reclaim your time?
    </h2>
    <p
      class="text-xl text-text-muted max-w-[600px] mx-auto mb-10 leading-[1.6] m-0"
    >
      Join community managers and business owners who rely on WA+ for fast,
      private, and reliable group exports.
    </p>

    <div class="flex flex-col md:flex-row justify-center gap-5 items-center w-full px-6 md:px-0">
      <a
        href="https://chromewebstore.google.com/detail/wa+/fkhdjggogknhlhaopaameedhchhoomhm"
        target="_blank"
        rel="noopener noreferrer"
        class="w-full md:w-auto bg-primary text-white py-4 px-9 rounded-2xl text-[18px] font-semibold no-underline transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] shadow-[0_8px_24px_-6px_rgba(16,185,129,0.5)] font-inter relative overflow-hidden hover:-translate-y-[3px] hover:scale-[1.02] hover:shadow-[0_12px_30px_-8px_rgba(16,185,129,0.6)] hover:bg-primary-hover group"
      >
        <span class="relative z-10">Add to Chrome 👀 It's Free</span>
        <div
          class="absolute top-0 -left-full w-1/2 h-full bg-gradient-to-r from-transparent via-white/20 to-transparent transition-all duration-500 group-hover:left-full"
        >
        </div>
      </a>
      <a
        href="#"
        class="w-full md:w-auto bg-surface text-text-main border border-border-subtle py-4 px-9 rounded-2xl text-[18px] font-semibold no-underline transition-all relative overflow-visible hover:bg-zinc-800/80 hover:border-white/20 hover:shadow-[0_12px_30px_rgba(0,0,0,0.4)] group"
        onclick="event.preventDefault()"
      >
        Add to Firefox
        <span
          class="absolute -top-3 -right-[15px] bg-gradient-to-br from-amber-500 to-amber-700 text-white text-[11px] py-1 px-[10px] rounded-[12px] font-extrabold shadow-[0_4px_12px_rgba(245,158,11,0.4)] rotate-6 transition-transform duration-300 ease-[cubic-bezier(0.175,0.885,0.32,1.275)] group-hover:rotate-12 group-hover:scale-110"
          >Coming Soon</span
        >
      </a>
    </div>
  </div>

  <footer class="w-full mt-[120px] pt-16 pb-8 border-t border-white/5 bg-zinc-950/80 backdrop-blur-md">
    <div class="container mx-auto px-6 max-w-[1152px]">
      <div class="flex flex-col md:flex-row justify-between items-start gap-10 md:gap-20 mb-12">
        <!-- Brand & Description -->
        <div class="flex-1 max-w-[400px]">
          <a href="#hero" class="logo text-3xl font-extrabold text-text-main no-underline flex items-center gap-3 tracking-tight mb-4 transition-transform hover:scale-105">
            <div class="bg-gradient-to-br from-primary to-emerald-400 text-white w-10 h-10 rounded-lg flex items-center justify-center text-xl font-outfit shadow-[0_4px_12px_rgba(16,185,129,0.3)]">
              WA
            </div>
            WA+
          </a>
          <p class="text-text-muted text-sm leading-relaxed mb-6">
            The privacy-first, lightning-fast Chrome Extension for extracting WhatsApp Group participants. Secure, local, and completely free.
          </p>
          <!-- Social Icons -->
          <div class="flex gap-4">
            <!-- X (Twitter) -->
            <a href="https://x.com/Mazafard" target="_blank" aria-label="Follow us on X" class="w-10 h-10 rounded-full bg-surface border border-border-subtle flex items-center justify-center text-text-muted hover:text-white hover:border-primary/50 hover:shadow-[0_0_15px_rgba(16,185,129,0.2)] transition-all">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 24.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <!-- GitHub -->
            <a href="https://github.com/Mazafard/wa-plus" target="_blank" aria-label="View source on GitHub" class="w-10 h-10 rounded-full bg-surface border border-border-subtle flex items-center justify-center text-text-muted hover:text-white hover:border-primary/50 hover:shadow-[0_0_15px_rgba(16,185,129,0.2)] transition-all">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.416 22 12c0-5.523-4.477-10-10-10z"/></svg>
            </a>
            <!-- Instagram -->
            <a href="https://instagram.com/mazafard" target="_blank" aria-label="Follow us on Instagram" class="w-10 h-10 rounded-full bg-surface border border-border-subtle flex items-center justify-center text-text-muted hover:text-white hover:border-primary/50 hover:shadow-[0_0_15px_rgba(16,185,129,0.2)] transition-all">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
            <!-- Facebook -->
            <a href="https://facebook.com/mazafard" target="_blank" aria-label="Like us on Facebook" class="w-10 h-10 rounded-full bg-surface border border-border-subtle flex items-center justify-center text-text-muted hover:text-white hover:border-primary/50 hover:shadow-[0_0_15px_rgba(16,185,129,0.2)] transition-all">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
            </a>
            <!-- Email -->
            <a href="mailto:hello@example.com" aria-label="Email us" class="w-10 h-10 rounded-full bg-surface border border-border-subtle flex items-center justify-center text-text-muted hover:text-white hover:border-primary/50 hover:shadow-[0_0_15px_rgba(16,185,129,0.2)] transition-all">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </a>
          </div>
        </div>

        <!-- Links Columns -->
        <div class="flex gap-16 md:gap-24">
          <div class="flex flex-col gap-4">
            <h4 class="text-white font-semibold text-lg mb-2">Product</h4>
            <a href="#features" class="text-text-muted no-underline hover:text-primary transition-colors text-sm">Features</a>
            <a href="#how-it-works" class="text-text-muted no-underline hover:text-primary transition-colors text-sm">How it Works</a>
            <a href="#faq" class="text-text-muted no-underline hover:text-primary transition-colors text-sm">FAQ</a>
            <a href="#download" class="text-text-muted no-underline hover:text-primary transition-colors text-sm">Download</a>
          </div>
          
          <div class="flex flex-col gap-4">
            <h4 class="text-white font-semibold text-lg mb-2">Legal</h4>
            <a href="privacy.html" class="text-text-muted no-underline hover:text-primary transition-colors text-sm">Privacy Policy</a>
            <a href="https://github.com/Mazafard/wa-plus" target="_blank" class="text-text-muted no-underline hover:text-primary transition-colors text-sm">Terms of Service</a>
            <a href="https://github.com/Mazafard/wa-plus" target="_blank" class="text-text-muted no-underline hover:text-primary transition-colors text-sm">Source Code</a>
          </div>
        </div>
      </div>

      <!-- Bottom Bar -->
      <div class="border-t border-border-subtle pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-text-muted text-sm m-0">
          &copy; {new Date().getFullYear()} WA+ Extension. Not affiliated with WhatsApp Inc.
        </p>
        <div class="flex items-center gap-2 text-text-muted text-sm">
          Built with <span class="text-red-500 text-lg">♥</span> for community managers.
        </div>
      </div>
    </div>
  </footer>
</section>
