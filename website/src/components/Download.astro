---

---

<section class="curtain-section z-[4]" id="download">
  <div class="container bottom-cta text-center flex flex-col items-center">
    <h2 class="text-[48px] mt-24 mb-6 tracking-[-1px]">
      Ready to reclaim your time?
    </h2>
    <p
      class="text-xl text-text-muted max-w-[600px] mx-auto mb-10 leading-[1.6] m-0"
    >
      Join community managers and business owners who rely on WA+ for fast,
      private, and reliable group exports.
    </p>

    <div class="flex justify-center gap-5 items-center">
      <a
        href="https://chromewebstore.google.com/detail/wa+/fkhdjggogknhlhaopaameedhchhoomhm"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-primary text-white py-4 px-9 rounded-2xl text-[18px] font-semibold no-underline transition-all duration-300 ease-[cubic-bezier(0.16,1,0.3,1)] shadow-[0_8px_24px_-6px_rgba(16,185,129,0.5)] font-inter relative overflow-hidden hover:-translate-y-[3px] hover:scale-[1.02] hover:shadow-[0_12px_30px_-8px_rgba(16,185,129,0.6)] hover:bg-primary-hover group"
      >
        <span class="relative z-10">Add to Chrome 👀 It's Free</span>
        <div
          class="absolute top-0 -left-full w-1/2 h-full bg-gradient-to-r from-transparent via-white/20 to-transparent transition-all duration-500 group-hover:left-full"
        >
        </div>
      </a>
      <a
        href="#"
        class="bg-surface text-text-main border border-border-subtle py-4 px-9 rounded-2xl text-[18px] font-semibold no-underline transition-all relative overflow-visible hover:bg-zinc-800/80 hover:border-white/20 hover:shadow-[0_12px_30px_rgba(0,0,0,0.4)] group"
        onclick="event.preventDefault()"
      >
        Add to Firefox
        <span
          class="absolute -top-3 -right-[15px] bg-gradient-to-br from-amber-500 to-amber-700 text-white text-[11px] py-1 px-[10px] rounded-[12px] font-extrabold shadow-[0_4px_12px_rgba(245,158,11,0.4)] rotate-6 transition-transform duration-300 ease-[cubic-bezier(0.175,0.885,0.32,1.275)] group-hover:rotate-12 group-hover:scale-110"
          >Coming Soon</span
        >
      </a>
    </div>
  </div>

  <footer class="w-full mt-auto border-t border-white/5 py-8 text-center">
    <p class="text-text-muted text-sm m-0">
      &copy; 2026 WA+ Extension. Not affiliated with WhatsApp Inc.
    </p>
    <div class="mt-4 flex justify-center gap-6">
      <a
        href="privacy.html"
        class="text-text-muted no-underline text-sm hover:text-white transition-colors"
        >Privacy Policy</a
      >
      <a
        href="https://github.com/Mazafard/wa-plus"
        class="text-text-muted no-underline text-sm hover:text-white transition-colors"
        >GitHub Repository</a
      >
    </div>
  </footer>
</section>
