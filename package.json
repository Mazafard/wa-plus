{
  "name": "wa-plus",
  "description": "A professional tool to extract group participants and metadata seamlessly from WhatsApp Web.",
  "private": false,
  "version": "1.0.0",
  "type": "module",
  "author": "WA+ Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
